<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>Assembly-CSharp.SoflanSupport.mm</AssemblyName>
    <TargetFramework>net472</TargetFramework>
    <LangVersion>10.0</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <!-- 输出整洁: 仅产出 patch .mm.dll 自身, 不拷贝目标/Unity/System/MonoMod 等传递依赖 -->
    <CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
    <NoWarn>$(NoWarn);CS0626;CS0108;CS0114;CS0414;CS0169</NoWarn>
    <!-- 与 NetFx472 项目一致: net472 已内置 System.Linq.Append, 关闭 Core 里的自定义 Append 以免二义性 -->
    <DefineConstants>$(DefineConstants);HAS_SYSTEM_LINQ_APPEND</DefineConstants>
  </PropertyGroup>

  <!-- 子项目 (各有独立 .csproj, 不属于本 patch) 与参考代码不参与编译: 避免 SDK 递归纳入导致
       语法/引用冲突, 也避免其 bin 产物触发 MSBuild 程序集统一劫持 patch 引用版本. -->
  <ItemGroup>
    <Compile Remove="SoflanSimulator\**\*.cs" />
    <None Remove="SoflanSimulator\**" />
    <ProjectReference Remove="SoflanSimulator\**" />
    <Compile Remove="SoflanCalculator\**\*.cs" />
    <None Remove="SoflanCalculator\**" />
    <ProjectReference Remove="SoflanCalculator\**" />
    <Compile Remove="Dependencies\**\*.cs" />
    <None Remove="Dependencies\**" />
    <ProjectReference Remove="Dependencies\**" />
    <Compile Remove="_decompiled\**\*.cs" />
    <None Remove="_decompiled\**" />
    <Compile Remove="tools\**\*.cs" />
    <None Remove="tools\**" />
    <ProjectReference Remove="tools\**" />
    <Compile Remove="tmp_ma2_export_check\**\*.cs" />
    <None Remove="tmp_ma2_export_check\**" />
    <ProjectReference Remove="tmp_ma2_export_check\**" />
  </ItemGroup>

  <ItemGroup>
    <!-- 目标程序集(真实, 非公开化). 仅编译期引用, 不拷贝 -->
    <Reference Include="Assembly-CSharp">
      <HintPath>F:\SDEZ_165\Package\Sinmai_Data\Managed\Assembly-CSharp.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <!-- 外部依赖: 提供 SimpleSoflanFramework.Core / OngekiFumenEditor.Core.* 命名空间.
         改用 Shared Project (projitems) 直接把源码编进 .mm.dll, 无需单独部署 Core.dll. -->
    <!-- (Shared Project 的 Import 见文件末尾) -->
    <!-- Unity 运行时类型 -->
    <Reference Include="UnityEngine">
      <HintPath>F:\SDEZ_165\Package\Sinmai_Data\Managed\UnityEngine.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>F:\SDEZ_165\Package\Sinmai_Data\Managed\UnityEngine.CoreModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <!-- IMGUI (OnGUI/GUILayout/GUI) — 调试面板用 -->
    <Reference Include="UnityEngine.IMGUIModule">
      <HintPath>F:\SDEZ_165\Package\Sinmai_Data\Managed\UnityEngine.IMGUIModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <!-- Input (GetMouseButtonDown/mousePosition) — 右键选 note 用 -->
    <Reference Include="UnityEngine.InputModule">
      <HintPath>F:\SDEZ_165\Package\Sinmai_Data\Managed\UnityEngine.InputModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <!-- Physics2D (OverlapPointAll/BoxCollider2D) — 点击命中 note 用 -->
    <Reference Include="UnityEngine.Physics2DModule">
      <HintPath>F:\SDEZ_165\Package\Sinmai_Data\Managed\UnityEngine.Physics2DModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <!-- MonoMod: 引用 BepInEx 随附的经典 MonoMod (v20.5.21.5, 与游戏运行时一致),
         而非 NuGet MonoMod.Patcher 25.0.1, 避免 .mm.dll 的 MonoMod AssemblyRef 与运行时版本错配.
         MonoModRules.cs 用 Cecil API 做 IL 插入, 故一并引用 BepInEx 的 Mono.Cecil 0.10.4. -->
    <Reference Include="MonoMod">
      <HintPath>F:\SDEZ_165\Package\BepInEx\core\MonoMod.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="MonoMod.Utils">
      <HintPath>F:\SDEZ_165\Package\BepInEx\core\MonoMod.Utils.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Mono.Cecil">
      <HintPath>F:\SDEZ_165\Package\BepInEx\core\Mono.Cecil.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Mono.Cecil.Pdb">
      <HintPath>F:\SDEZ_165\Package\BepInEx\core\Mono.Cecil.Pdb.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Mono.Cecil.Mdb">
      <HintPath>F:\SDEZ_165\Package\BepInEx\core\Mono.Cecil.Mdb.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <!-- SimpleSoflanFramework.Core 以 Shared Project 形式引入: projitems 内用显式
       $(MSBuildThisFileDirectory)*.cs 路径 Include, 放在顶部 Compile Remove="Dependencies\**"
       之后, 故这些源码会被重新纳入编译并直接内置进 .mm.dll. -->
  <Import Project="Dependencies\SimpleSoflanFramework\SimpleSoflanFramework.Core\SimpleSoflanFramework.Core.projitems" Label="Shared" />
</Project>
